[user]
    email = michael@
    name = Michael Welter
    signingkey = ~/.ssh/id_ed25519.pub
[init]
    defaultBranch = main
[color]
    status = auto
    diff = auto
    interactive = auto
    ui = auto
[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
[alias]
    alias = !git config --list | grep 'alias\\.' | sed 's/alias\\.\\([^=]*\\)=\\(.*\\)/\\1\\t=> \\2/' | sort
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset %C(cyan)[%an]%Creset {%G?}' --abbrev-commit --date=relative
    staged = diff --cached
    unstage = reset HEAD --
    undo = reset --soft HEAD~1
    compare = !git --no-pager log origin/main..HEAD --abbrev-commit --pretty=oneline --date=relative
    cleanup = !git branch --merged main | grep -v 'main$' | xargs git branch -d
    amend = !git log -n 1 --pretty=tformat:%s%n%n%b | git commit -F - --amend
    last = log -1 HEAD
    email = config user.email
[format]
    numbered = auto
[core]
    whitespace = -trailing-space
    excludesfile = ~/.gitignore
[repack]
    usedeltabaseoffset = true
[branch]
    autosetupmerge = always
    autosetuprebase = always
[pager]
    color = true
    status = false
[push]
    default = current
[rebase]
    autosquash = true
[commit]
    gpgsign = true
    signoff = true
[gpg]
    format = ssh
[gpg "ssh"]
    allowedSignersFile = ~/.ssh/allowed_signers
